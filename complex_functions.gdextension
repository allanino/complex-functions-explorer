[configuration]

entry_symbol = "complex_functions_library_init"
compatibility_minimum = 4.1

[libraries]

linux.debug.x86_64 = "res://bin/libcomplex_functions.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libcomplex_functions.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://bin/libcomplex_functions.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/libcomplex_functions.windows.template_release.x86_64.dll"
