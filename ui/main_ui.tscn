theme_override_styles/pressed = SubResource("StyleBoxFlat_btn_pressed")
text = "Exit"

[node name="MenuOverlay" parent="Control" instance=ExtResource("4_menu")]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="TooltipManager" type="CanvasLayer" parent="."]
unique_name_in_owner = true
layer = 128
script = ExtResource("5_tooltip_manager")

[node name="TooltipTimer" type="Timer" parent="TooltipManager"]
unique_name_in_owner = true
wait_time = 0.4
one_shot = true

[node name="Tooltip" type="PanelContainer" parent="TooltipManager"]
unique_name_in_owner = true
visible = false
layout_mode = 0
mouse_filter = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_tooltip")

[node name="MarginContainer" type="MarginContainer" parent="TooltipManager/Tooltip"]
layout_mode = 2
mouse_filter = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="TooltipLabel" type="RichTextLabel" parent="TooltipManager/Tooltip/MarginContainer"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/default_color = Color(0.9, 0.9, 0.9, 1)
theme_override_font_sizes/normal_font_size = 18
bbcode_enabled = true
fit_content = true
autowrap_mode = 2

[node name="PresetController" type="Node" parent="."]
unique_name_in_owner = true
script = ExtResource("6_preset_controller")
